# Flickr to Instagram Automation - Environment Variables Template
# Copy this file to .env and fill in your actual values

# === SHARED CONFIGURATION (Used by both accounts) ===
FLICKR_API_KEY=your_flickr_api_key_here
FLICKR_USER_ID=your_flickr_user_id_here
FLICKR_USERNAME=your_flickr_username_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Configuration for Git-based state management
GITHUB_TOKEN=your_github_fine_grained_pat_here  # Fine-grained PAT with contents:write permission only
GITHUB_REPOSITORY=username/repository-name

# API Configuration
GRAPH_API_VERSION=v18.0
ANTHROPIC_MODEL=claude-sonnet-4-6

# === PRIMARY ACCOUNT CONFIGURATION ===
FLICKR_ALBUM_ID=your_primary_album_id_here
INSTAGRAM_ACCESS_TOKEN=your_primary_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_primary_instagram_account_id_here

# === REISEMEMO ACCOUNT CONFIGURATION ===
FLICKR_ALBUM_ID_REISEMEMO=your_reisememo_album_id_here
INSTAGRAM_ACCESS_TOKEN_REISEMEMO=your_reisememo_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID_REISEMEMO=your_reisememo_instagram_account_id_here

# === SECONDARY ACCOUNT SETTINGS (optional overrides; defaults work for reisememo.ch) ===
# SECONDARY_ACCOUNT_ID=reisememo                # CLI --account value
# SECONDARY_ACCOUNT_NAME=Reisememo               # Display name used in captions/emails
# SECONDARY_ENVIRONMENT_NAME=secondary-account   # GitHub Environment name
# SECONDARY_ACCOUNT_LANGUAGE=de                  # Caption language: en, de, ...
# SECONDARY_BRAND_SIGNATURE=Reisememo von einem einzigartigen Reiseerlebnis.
# SECONDARY_BLOG_DOMAINS=reisememo.ch            # Comma-separated; first entry is primary
# Content path (WordPress custom endpoint + outbound request identity). Defaults
# match travelmemo.com's plugin/namespace, which reisememo.ch shares - only set
# these if the secondary account's WordPress setup diverges.
# SECONDARY_WP_ENDPOINT_NAMESPACE=travelmemo-content/v1
# SECONDARY_WP_AUTH_KEY=tm-post-retrieval
# SECONDARY_USER_AGENT=Reisememo-ContentFetcher/1.0  # Defaults to "<display name, spaces removed>-ContentFetcher/1.0"

# === OPTIONAL CONFIGURATION ===
# Logging Configuration
LOG_LEVEL=INFO

# State Management Configuration
STORAGE_BACKEND=git          # Use 'git' for modern Git-based storage (default), 'variables' for legacy repository variables
STATE_BRANCH=automation-state # Git branch for state storage (default: automation-state)

# Legacy State Management (deprecated - use Git-based storage instead)
# CREATE_AUDIT_ISSUES=true   # Creates GitHub issues for each successful post (not recommended for thousands of photos)
# CREATE_AUDIT_ISSUES=false  # Default: Use Git-based state files (recommended for scale and security)

# Blog Configuration
BLOG_POST_URL=https://your-blog-url.com/post-with-photo-context

# Email Notification Configuration (optional - sends completion notifications)
# NOTIFICATION_EMAIL=manager@company.com     # Email address to receive completion notifications
# SMTP_HOST=smtp.gmail.com                  # SMTP server (defaults to Gmail)
# SMTP_PORT=587                             # SMTP port (defaults to 587)
# SMTP_USERNAME=your.email@gmail.com        # Email account for sending notifications
# SMTP_PASSWORD=your_app_password_here      # App password for email account (not regular password)

# === FACEBOOK PAGE CROSS-POSTING (optional, posted immediately after Instagram) ===
# FACEBOOK_PAGE_ID=your_facebook_page_id_here
# FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# === THREADS CROSS-POSTING (optional, posted N hours after Instagram) ===
# Threads (Meta) uses graph.threads.net. An Instagram-Business IGAA... token with
# threads_basic + threads_content_publish scopes typically covers both platforms,
# but the Threads user ID is different from the Instagram account ID.
# THREADS_USER_ID=your_threads_user_id_here
# THREADS_ACCESS_TOKEN=your_threads_access_token_here
# THREADS_POST_DELAY_HOURS=8                 # Hours to wait after Instagram before posting to Threads
# THREADS_API_VERSION=v1.0                   # Threads Graph API version